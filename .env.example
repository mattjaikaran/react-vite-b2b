# =============================================================================
# React Vite B2B - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
# IMPORTANT: Vite only exposes variables prefixed with VITE_

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# API URL (leave empty to use proxy in development)
VITE_API_URL=

# For production, set to your API URL
# VITE_API_URL=https://api.example.com

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable features (true/false)
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false

# -----------------------------------------------------------------------------
# Third-party Services (Optional)
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# Analytics/Tracking
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX
# VITE_MIXPANEL_TOKEN=xxxxx

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
# App name (displayed in title and UI)
VITE_APP_NAME=MyApp

# Default organization plan
VITE_DEFAULT_ORG_PLAN=free
